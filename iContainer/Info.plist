<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sparkle auto-update. Other Info.plist keys are still generated by
	     Xcode (GENERATE_INFOPLIST_FILE = YES merges them on top of this file). -->
	<key>SUFeedURL</key>
	<string>https://raw.githubusercontent.com/nico81/iContainer/main/appcast.xml</string>
	<!-- EdDSA public key printed by Sparkle's `generate_keys`. The matching
	     private key lives only in the maintainer's keychain and signs each
	     release via `sign_update` / `generate_appcast`. -->
	<key>SUPublicEDKey</key>
	<string>Qe5bUFxV3v1BKnRnHuZRwGY6oUU1IFHTkFi+XBfLGjo=</string>
	<!-- Check for updates automatically in the background, then prompt the
	     user (Sparkle does not install silently by default). -->
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>
